# Supabase project URL (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"

# Supabase publishable key (formerly "anon/public key") — safe to expose to the browser (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Supabase service_role key — server-side ONLY, never expose to the browser or commit real value
# Used by our own API routes to perform privileged Supabase operations (e.g. creating profiles)
SUPABASE_SERVICE_ROLE_KEY="ey..."

# Direct Postgres connection string — includes the database password you set when creating the project
# Use the pooled ("-pooler" / port 6543) version for serverless functions to avoid exhausting connections
# Non-pooled (port 5432) version is fine for one-off scripts/migrations run locally
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[DB-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Optional. Public site URL used to build the email confirmation redirect link
# (POST /api/auth/register sets emailRedirectTo to `${NEXT_PUBLIC_SITE_URL}/api/auth/confirm`).
# If unset, Supabase falls back to the `site_url` configured in supabase/config.toml.
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"
